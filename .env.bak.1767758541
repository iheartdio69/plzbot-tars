# Whale tiers (based on single tx size)
BELUGA_SOL_TX=2.0
BLUE_SOL_TX=5.0

# Filters
AVOID_BONK=true

# Debug
DEBUG_EVERY_N_SCANS=100
DEBUG_VERBOSE_CALLS=false