# Fetching limits
FETCH_LIMIT=100

# Loop timing
MAIN_LOOP_SLEEP=2
MARKET_POLL_SECS=20

# Window settings
WINDOW_SECS=300
EVENTS_KEEP_SECS=1200
SNAPSHOT_INTERVAL_SECS=5

# Coin age filters
MIN_SCAN_AGE_SECS=30
MAX_COIN_AGE_SECS=172800  # 48 hours
MIN_AGE_SECS=60

# Market bands
MIN_WATCH_FDV_USD=15000
MAX_WATCH_FDV_USD=250000
MIN_CALL_FDV_USD=20000
MAX_CALL_FDV_USD=120000
MIN_LIQ_USD=5000

# Discovery settings
MARKET_DISCOVERY_ENABLED=true
MARKET_DISCOVERY_QUERIES=pump,solana,raydium
MARKET_DISCOVERY_EVERY_SECS=60
MARKET_DISCOVERY_TOP_N=50
DISCOVERY_MIN_FDV_USD=15000
DISCOVERY_MIN_LIQ_USD=5000
DISCOVERY_MIN_TX_5M=20

# Scoring thresholds
SCORE_TARGET=70
SCORE_DEMOTE=45
DEMOTE_STREAK=4

# Activity requirements for call
MIN_SIGNERS_FOR_TARGET=20
MIN_TX_FOR_TARGET=40

# Focus management
