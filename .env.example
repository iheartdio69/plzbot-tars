# Helius API
HELIUS_API_KEY=your_helius_api_key
HELIUS_ADDR_URL=https://api.helius.xyz/v0/addresses
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WALLETS=wallet1,wallet2,wallet3

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Trading (set TARS_ENABLED=true to go live)
TARS_ENABLED=false
TARS_BUY_SOL=0.1
TARS_TP1_MULT=1.5
TARS_TP2_MULT=2.0
TARS_SL_PCT=0.30
TARS_PRIVATE_KEY=your_wallet_private_key

# PumpPortal
PUMPPORTAL_PUBLIC_KEY=your_public_key
PUMPPORTAL_PRIVATE_KEY=your_private_key
PUMPPORTAL_API_KEY=your_api_key

# Discovery tuning
MARKET_DISCOVERY_ENABLED=true
MARKET_DISCOVERY_EVERY_SECS=15
MARKET_DISCOVERY_TOP_N=50
DISCOVERY_MIN_FDV_USD=10000

# Scoring
SCORE_TARGET=20
MAX_ACTIVE_COINS=25
MAX_CALL_FDV_USD=500000
MIN_CALL_FDV_USD=10000

# Database
SQLITE_PATH=./data/STUPID_MAIN_DB_DO_NOT_TOUCH.sqlite
