#!/bin/bash
echo "🧬 Building INTERFECTOR..."
cargo build --release 2>&1 | grep -E "^error|^warning"
echo "✅ Build OK — bringing systems online..."

# Kill existing processes
pkill solana_meme 2>/dev/null
pkill dashboard 2>/dev/null
lsof -ti:3000 | xargs kill -9 2>/dev/null
sleep 3

# Launch dashboard in background
./target/release/dashboard > dashboard.log 2>&1 &
echo "🌊 TARS Dashboard live at http://localhost:3000"

# Launch bot in foreground with debug
echo "🎯 INTERFECTOR online..."
DEBUG=1 ./target/release/solana_meme 2>&1 | tee bot_debug.log
