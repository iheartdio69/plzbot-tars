// src/helius/client.rs
use crate::config::Config;
use crate::types::{CoinState, Event, WhaleTier};
use reqwest::Client;
use serde_json::Value;
use std::collections::HashMap;

/// Fetch recent transactions for tracked mints using Helius REST API (FREE)
/// GET https://api.helius.xyz/v0/addresses/{address}/transactions?api-key=KEY&limit=...
pub async fn fetch_onchain_events(cfg: &Config, coins: &mut HashMap<String, CoinState>) {
    // If no key, don't spam requests
    if cfg.helius_api_key.trim().is_empty() {
        return;
    }

    let client = Client::new();
    let base = cfg.helius_addr_url.trim_end_matches('/');

    // Copy keys first (avoids borrow issues)
    let mints: Vec<String> = coins.keys().cloned().collect();

    for mint in mints {
        // Only call for things that look like a real base58 pubkey (optional hard gate)
        // If you don't want this gate, remove this block.
        let url = format!(
            "{}/v0/addresses/{}/transactions?api-key={}&limit={}",
            base,
            mint,
            cfg.helius_api_key.trim(),
            cfg.fetch_limit,
        );
        eprintln!("DBG helius url={}", url);

        let resp = match client.get(&url).send().await {
            Ok(r) => r,
            Err(_) => continue,
        };

        if !resp.status().is_success() {
            // ignore noisy failures (invalid addr / rate limit / etc.)
            continue;
        }

        let txs: Vec<Value> = match resp.json().await {
            Ok(j) => j,
            Err(_) => continue,
        };
        eprintln!("DBG helius mint={} txs_len={}", mint, txs.len());
        if let Some(first) = txs.get(0) {
            if let Some(obj) = first.as_object() {
                let keys: Vec<&String> = obj.keys().collect();
                eprintln!("DBG helius first_keys={:?}", keys);
            }
        }

        let Some(state) = coins.get_mut(mint.as_str()) else {
            continue;
        };

        let empty_vec = vec![];

        for tx in &txs {
            // Helius enhanced tx shape:
            // - timestamp (seconds)
            // - feePayer
            // - nativeTransfers: [{fromUserAccount,toUserAccount,amount}] where amount is lamports
            let ts = tx["timestamp"].as_u64().unwrap_or(0);
            let fee_payer = tx["feePayer"].as_str().unwrap_or("").to_string();

            let native = tx["nativeTransfers"].as_array().unwrap_or(&empty_vec);

            // Sum lamports where fee_payer is the sender
            let mut lamports_out: u64 = 0;
            for nt in native {
                let from = nt["fromUserAccount"].as_str().unwrap_or("");
                if from == fee_payer {
                    lamports_out += nt["amount"].as_u64().unwrap_or(0);
                }
            }

            let sol_amount = lamports_out as f64 / 1_000_000_000.0;
            if sol_amount < 0.01 {
                continue;
            }

            let tier = if sol_amount >= cfg.blue_sol_tx {
                WhaleTier::Blue
            } else if sol_amount >= cfg.beluga_sol_tx {
                WhaleTier::Beluga
            } else {
                WhaleTier::None
            };

            state.events.push(Event {
state.events.push(Event {
                wallet: fee_payer,
                ts: block_time,
                sol: sol_amount,
                tier,
            });
        }
    }
}
