pub use counters::Counters;
pub use context::{Services, Collections};
pub use score::score_all_coins;
pub use active::{update_active_list, promote_from_queue};
pub use queue::fill_queue;
pub use calls::process_calls;
pub use summary::print_summary;

use crate::config::Config;
use crate::market::cache::MarketCache;
use crate::scoring::shadow::ShadowMap;
use crate::db::Db;
use std::collections::{HashMap, VecDeque};
use crate::types::{CoinState, CallRecord};

pub fn score_and_manage(
    cfg: &Config,
    coins: &mut HashMap<String, CoinState>,
    active: &mut Vec<String>,
    queue: &mut VecDeque<String>,
    calls: &mut Vec<CallRecord>,
    market: &MarketCache,
    shadow_map: &mut ShadowMap,
    db: &mut Db,
) {
    let mut counters = Counters::default();

    let services = Services { cfg, market, shadow_map, db };
    let mut collections = Collections { coins, active, queue, calls };

    score_all_coins(&services, &mut collections, &mut counters);
    update_active_list(&services, &mut collections, &mut counters);
    fill_queue(&services, &mut collections, &mut counters);
    promote_from_queue(&services, &mut collections, &mut counters);
    let shadowed_after_call = process_calls(&services, &mut collections, &mut counters);
    active::remove_shadowed(&mut collections.active, shadowed_after_call);
    print_summary(&counters, collections.active.len(), collections.queue.len());
}
pub mod constants;


